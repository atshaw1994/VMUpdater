<Application x:Class="VMUpdater.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:VMUpdater.Helpers"
             xmlns:local="clr-namespace:VMUpdater"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             ThemeMode="System"
             Startup="Application_Startup"
             Exit="Application_Exit">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/PresentationFramework.Fluent;component/themes/Fluent.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <helpers:InverseBooleanConverter x:Key="InverseBooleanConverter" />
            <helpers:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <helpers:DateTimeToPartsConverter x:Key="DateTimeToPartsConverter" />

            <tb:TaskbarIcon x:Key="NotifyIcon"
                            IconSource="pack://application:,,,/Resources/VMUpdater.ico">
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu x:Name="TrayContextMenu">
                        <MenuItem x:Name="MenuOpen" Header="Open VMUpdater" />
                        <MenuItem x:Name="MenuOpenLog" Header="Open Log" />
                        <MenuItem x:Name="MenuUpdateNow" Header="Update Now" />
                        <Separator />
                        <MenuItem x:Name="MenuExit" Header="Exit" />
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>
        </ResourceDictionary>
    </Application.Resources>
</Application>