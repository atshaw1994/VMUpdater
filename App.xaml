<Application x:Class="VMUpdater.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:VMUpdater.Helpers"
             xmlns:local="clr-namespace:VMUpdater"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             ThemeMode="System"
             Startup="Application_Startup"
             Exit="Application_Exit">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PresentationFramework.Fluent;component/themes/Fluent.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <tb:TaskbarIcon x:Key="NotifyIcon"
                            IconSource="pack://application:,,,/Resources/VMUpdater.ico">
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu x:Name="TrayContextMenu">
                        <MenuItem x:Name="MenuOpen" Header="Open" />
                        <MenuItem x:Name="MenuOpenLog" Header="Open Log" />
                        <Separator />
                        <MenuItem x:Name="MenuExit" Header="Exit" />
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>

            <Style x:Key="AddGlyphStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="FontFamily" Value="Segoe Fluent Icons"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
                <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
                <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>