<UserControl x:Class="VMUpdater.Views.VirtualMachineEntry"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:VMUpdater.Views"
             xmlns:vm="clr-namespace:VMUpdater.ViewModels"
             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:VirtualMachineViewModel, IsDesignTimeCreatable=False}"
             d:DesignWidth="800">
    <Grid Margin="2">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Button Height="30" 
                HorizontalAlignment="Stretch" 
                HorizontalContentAlignment="Right" 
                d:Background="White"
                Command="{Binding ToggleExpandCommand}">
            <TextBlock Text="{Binding ExpandedIcon}" 
                       d:Text="&#xE70E;"
                       FontFamily="Segoe Fluent Icons" 
                       d:Foreground="Black"
                       Foreground="{DynamicResource ControlStrongStrokeColorDefaultBrush}" 
                       HorizontalAlignment="Right" 
                       VerticalAlignment="Center"/>
        </Button>
        
        <TextBlock IsHitTestVisible="False" 
                   FontSize="16" 
                   VerticalAlignment="Center" 
                   Margin="8,0"
                   d:Text="New Virtual Machine (Windows 11)">
            <TextBlock.Text>
                <MultiBinding StringFormat="{}{0} ({1})">
                    <Binding Path="DisplayName" UpdateSourceTrigger="PropertyChanged"/>
                    <Binding Path="GuestOSType" UpdateSourceTrigger="PropertyChanged"/>
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <Border x:Name="DetailsPanel"
                Grid.Row="1"
                Background="{DynamicResource ControlFillColorDefaultBrush}" 
                BorderBrush="{DynamicResource ControlElevationBorderBrush}" 
                d:Background="White" d:Visibility="Visible" d:Height="Auto"
                Margin="16,0,3,8"
                BorderThickness="1,0,1,1"
                CornerRadius="0,0,4,4" >
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Height" Value="0"/>
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                            <Setter Property="Height" Value="Auto"/>
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Margin="4,8,4,4">
                <StackPanel Margin="0,0,0,2">
                    <TextBlock Text="Path to virtual machine:"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Content="Browse..." Margin="0,0,8,0" Command="{Binding BrowseCommand}"/>
                        <TextBox Grid.Column="1" Text="{Binding VMPath, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </StackPanel>

                <TextBlock Text="Guest OS:"/>
                <ComboBox x:Name="VMTypeComboBox" 
                          Margin="0,2"
                          SelectedValue="{Binding GuestOSType, UpdateSourceTrigger=PropertyChanged}" 
                          SelectedValuePath="Content">
                    <ComboBoxItem Content="Arch Linux" />
                    <ComboBoxItem Content="Fedora Linux" />
                    <ComboBoxItem Content="Debian Linux" />
                    <ComboBoxItem Content="Windows" />
                </ComboBox>

                <Grid Margin="0,2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Username:" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBox x:Name="UsernameTextBox" Grid.Column="1" Margin="0,0,0,4" VerticalAlignment="Center" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Password:" Grid.Column="2" Margin="8,0" VerticalAlignment="Center"/>
                    <TextBox x:Name="PasswordTextBox" Grid.Column="3" Margin="0,0,0,4" VerticalAlignment="Center" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Every" Grid.Row="1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="ScheduleComboBox" 
                              Grid.Column="1" 
                              Grid.Row="1"
                              SelectedValue="{Binding ScheduleDay, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Content">
                        <ComboBoxItem Content="Monday" />
                        <ComboBoxItem Content="Tuesday" />
                        <ComboBoxItem Content="Wednesday" />
                        <ComboBoxItem Content="Thursday" />
                        <ComboBoxItem Content="Friday" />
                        <ComboBoxItem Content="Saturday" />
                        <ComboBoxItem Content="Sunday" />
                    </ComboBox>
                    <TextBlock Text="at" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="2"/>
                    <local:TimePicker Grid.Column="3" Grid.Row="1" HorizontalAlignment="Center" SelectedTime="{Binding ScheduleTime, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding LastUpdateDisplayText}" d:Text="Last Update: January 1, 0001 at 12:00 AM"/>
                        <TextBlock Grid.Row="1" Text="{Binding NextUpdateDisplayText}" d:Text="Next Update: January 1, 0001 at 12:00 AM"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Grid.Column="1">
                        <Button Height="30" HorizontalAlignment="Right" HorizontalContentAlignment="Right" Margin="4"
                                Command="{Binding DataContext.RemoveVirtualMachineCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ItemsControl}}}"
                                CommandParameter="{Binding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xe74d;" Margin="0,0,4,0" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center"/>
                                <TextBlock Text="Delete" Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </Grid>
                        </Button>

                        <Button Height="30" HorizontalAlignment="Right" HorizontalContentAlignment="Right" Margin="4" Command="{Binding UpdateNowCommand}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE896;" Margin="0,0,4,0" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center"/>
                                <TextBlock Text="Update" Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
