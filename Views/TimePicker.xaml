<UserControl x:Class="VMUpdater.Views.TimePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:VMUpdater.Views"
             x:Name="Root"
             mc:Ignorable="d">
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

        <ComboBox ItemsSource="{Binding Hours, ElementName=Root}"
                  SelectedItem="{Binding SelectedHour, ElementName=Root}"
                  ItemStringFormat="D2" 
                  Margin="0,0,5,0" />

        <TextBlock Text=":" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold"/>

        <ComboBox ItemsSource="{Binding Minutes, ElementName=Root}"
                  SelectedItem="{Binding SelectedMinute, ElementName=Root}"
                  ItemStringFormat="D2" 
                  Margin="0,0,5,0" />

        <ComboBox ItemsSource="{Binding Meridians, ElementName=Root}"
                  SelectedItem="{Binding SelectedMeridian, ElementName=Root}" />

    </StackPanel>
</UserControl>
